# ============================================================
# LLM Backend — choose one: ollama (local, free) | anthropic | openai
# ============================================================
LLM_BACKEND=ollama

# --- Ollama (local, free, no API key needed) ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434

# --- Anthropic Claude (better quality, costs ~$0.01/video) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI GPT ---
# OPENAI_API_KEY=sk-...

# ============================================================
# Whisper transcription
# ============================================================
# tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# Language code or "auto" for auto-detect
DEFAULT_LANGUAGE=auto

# ============================================================
# Clip generation
# ============================================================
MAX_CLIPS=5
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=90

# vertical (9:16) | square (1:1) | horizontal (16:9)
DEFAULT_FORMAT=vertical
