# LLM API key for smart clip detection
# Use ONE of these:
ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# Whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# Default language (auto = auto-detect)
DEFAULT_LANGUAGE=auto

# Max clips to generate per video
MAX_CLIPS=5

# Default clip duration range (seconds)
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=90

# Default output format: vertical (9:16), square (1:1), horizontal (16:9)
DEFAULT_FORMAT=vertical
